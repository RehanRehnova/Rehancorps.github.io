{
  "manifest_version": 3,
  "name": "REHNOVA Passfill",
  "short_name": "Passfill",
  "version": "1.4.0",
  "description": "Generate strong passwords on signup fields, save logins, autofill on return. AES-GCM locked vault. 100% local — Chrome, Edge, Brave, Firefox. © REHNOVA.",
  "author": "REHNOVA",
  "permissions": ["storage", "activeTab", "scripting"],
  "host_permissions": ["http://*/*", "https://*/*"],
  "action": {
    "default_title": "REHNOVA Passfill — generate, save, fill",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["http://*/*", "https://*/*"],
      "js": ["lib/password.js", "content.js"],
      "css": ["content.css"],
      "run_at": "document_idle",
      "all_frames": false
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "passfill@rehnova.proton.me",
      "strict_min_version": "115.0"
    }
  }
}
